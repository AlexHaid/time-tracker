generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  name         String?
  passwordHash String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  entries      TimeEntry[]
}

model TimeEntry {
  id           String   @id @default(cuid())
  name         String
  description  String   @default("")
  date         String   // YYYY-MM-DD
  spentMinutes Int
  type         String   @default("development") // "development" | "meeting"
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, date])
}
